{
  "expo": {
    "name": "BeerNow",
    "slug": "MobileFrontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/imagenes/BeerNow_icon_1024.png",
    "scheme": "beernow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.josemb02.beernow",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BeerNow needs your location to record where you enjoyed each beer.",
        "NSLocationAlwaysUsageDescription": "BeerNow needs your location to record where you enjoyed each beer.",
        "NSPhotoLibraryUsageDescription": "BeerNow needs access to your photos so you can add images to your check-ins and change your avatar.",
        "NSPhotoLibraryAddUsageDescription": "BeerNow needs permission to save photos to your gallery.",
        "NSCameraUsageDescription": "BeerNow needs access to your camera so you can take photos for your check-ins."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.josemb02.beernow"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/imagenes/BeerNow_icon_1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/imagenes/BeerNow_icon_1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F4EC",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6211707002961230~8079379180",
          "iosAppId": "ca-app-pub-6211707002961230~2273899024"
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53f42ea9-884f-470f-8f6b-e0a236a94777"
      }
    },
    "owner": "josemb02"
  }
}
